# Keep the docker build context lean. Everything listed here is either
# generated, environment-specific, or unused by `cargo build` inside
# the builder stage.

# Build outputs and caches
target/
**/target/
**/*.rs.bk

# VCS metadata
.git/
.gitattributes

# Editor / IDE state
.idea/
.vscode/
.claude/
.editorconfig

# CI / community docs not needed at build time
.github/
docs/
SECURITY.md
CONTRIBUTING.md
CHANGELOG.md

# Local environment artefacts
.env
.env.*
*.log

# OS junk
.DS_Store
Thumbs.db
