fn pick(flag: Bool) -> String {
  if flag {
    "yes"
  }
  else {
    "no"
  }
}

print $ pick true

for item in 0..3 {
  print item
}

let items = [3, 4]
for item in items {
  print item
}

let pair = (5, 6)
for item in pair {
  print item
}

let count = 0
while count < 2 {
  print count
  let count = count + 1
}

loop {
  print 9
  break
}

enum Option {
  None,
  Some(Int),
}

let maybe = Option::Some(7)
if let Option::Some(it) = maybe && it == 7 {
  print it
}
